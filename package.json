    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "stylelint-scss": "^7.0.0",
    "svgo": "^3.3.2",
    "three": "^0.183.2",
    "toml": "^4.1.1",
    "xslt3": "^2.7.0",
